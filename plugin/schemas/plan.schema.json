{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://martinez.methods/cdcc/schemas/plan.schema.json",
  "title": "Plan",
  "description": "CDCC Plan artifact — output of cdcc generate",
  "type": "object",
  "required": ["schemaVersion", "id", "createdAt", "bundle", "stages"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "id": {
      "type": "string",
      "description": "UUID v4 plan identifier"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 creation timestamp"
    },
    "bundle": {
      "type": "object",
      "description": "References to the source D2R bundle documents",
      "required": ["prd", "trd", "avd", "tqcd"],
      "additionalProperties": false,
      "properties": {
        "prd": { "$ref": "#/definitions/BundleRef" },
        "trd": { "$ref": "#/definitions/BundleRef" },
        "avd": { "$ref": "#/definitions/BundleRef" },
        "tqcd": { "$ref": "#/definitions/BundleRef" }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Stage" }
    }
  },
  "definitions": {
    "BundleRef": {
      "type": "object",
      "required": ["path", "sha256"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string" }
      }
    },
    "Stage": {
      "type": "object",
      "required": ["id", "name", "assignedModel", "effortLevel", "specDepth", "gate", "inputManifest", "skillInvocations"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "assignedModel": {
          "type": "string",
          "enum": ["opus-4-7", "sonnet-4-6", "haiku-4-5"]
        },
        "effortLevel": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "specDepth": {
          "type": "string",
          "enum": ["Shallow", "Medium", "Deep"]
        },
        "gate": {
          "type": "object",
          "required": ["threshold", "severityPolicy", "domain"],
          "additionalProperties": false,
          "properties": {
            "threshold": {
              "type": "integer",
              "minimum": 1
            },
            "severityPolicy": {
              "type": "string",
              "enum": ["strict", "standard"]
            },
            "domain": {
              "type": "string",
              "enum": ["code", "plan", "test", "audit", "general"]
            }
          }
        },
        "inputManifest": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for expected input paths"
        },
        "skillInvocations": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Skill identifiers required by this stage"
        }
      }
    }
  }
}
