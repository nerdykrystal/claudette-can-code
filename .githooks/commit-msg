#!/usr/bin/env bash
#
# commit-msg — Martinez Methods structural IP + gate enforcement (v05.1)
#
# CLASSIFICATION: INTERNAL ONLY — gate-script structure is mechanism-by-design
# and uses clustered methodology vocabulary as required-phrase regex targets.
# This file must not be published outside Martinez Methods. Public repos
# consuming this hook must have a separate scrub pass before publication.
#
# Composed rules (executed in order):
#
#   Rule 1: IP-clean persona attribution.
#     Co-Authored-By trailer's persona position must be Clauda or Claudette,
#     not Claude. Per memory feedback_clauda_replaces_claude_in_naming.md.
#
#   Rule 2: Gate-trailer presence at policy-required level.
#     Commit message must carry an ASAE-Gate: or D2R-Stage: trailer at the
#     level required by the repo's .asae-policy file.
#
#   Rule 3 (Tier 1): Backing-evidence existence.
#     The trailer must point at a real internal-records file under
#     deprecated/asae-logs/gate-NN-<descriptor>.md (staged in commit OR
#     existing in repo and referenced by gate-NN- in body), with required
#     frontmatter and N or more result-blocks.
#
#   Rule 3 (Tier 1b): Identical-pass discipline.
#     Each result-block must contain required-phrase markers indicating
#     full-domain checklist application AND severity summary line.
#
#   Rule 3 (Tier 1c, v04 addition): Independent rater attestation.
#     The internal-records file must contain an `## Independent Rater
#     Verification` section with non-placeholder verdict (CONFIRMED |
#     PARTIAL | FLAG). Per canonical methodology spec Step 6 (REQUIRED
#     for all gate invocations regardless of severity policy). Anti-
#     fabrication: faking the verdict is fabrication (F1) AND reproduces
#     the failure mode the rater step closes; methodology spec
#     prohibition is primary defense, this hook layer is secondary.
#
#   Rule 3 (Tier 1c-extended, v05 addition): Disclosures block presence.
#     For gates dated 2026-04-26 or later, frontmatter must contain a
#     `disclosures:` block with either `none: true` OR at least one
#     non-empty sub-block (known_issues / deviations_from_canonical /
#     omissions_with_reason / partial_completions). Per /asae Aspect 11
#     (FM-2.4 information withholding closure).
#
#   Rule 3 (Tier 1c-extended mode-conditional, v05): Step re-execution
#     trailer match. If frontmatter contains `step_re_execution:` block,
#     commit body must contain a matching `Step-Re-Execution:` trailer.
#     Per /asae Aspect 13 (FM-1.3 elevation).
#
#   Rule 4 (Tier 2-parse): For code commits in codebase repos, the
#     internal-records file must record literal exit-code claims for
#     test + build/typecheck/lint.
#
#   Rule 5 (Tier 3-parse): When staged files touch platform-conditional
#     paths, the file must record observed behavior in two or more shells.
#
#   Rule 6 (Tier 4): Provenance — gate_id unique in directory; frontmatter
#     must reference originating incident or session-dated event.
#
#   Rule 6 (Tier 4-extended, v05 addition): Session-chain resolution.
#     For gates dated 2026-04-26 or later, frontmatter must contain a
#     `session_chain:` block. Each entry's `path:` field must resolve to
#     an existing file (best-effort across known root locations). Per
#     /asae Aspect 10 (FM-2.1 conversation reset closure).
#
#   Rule 7 (Tier 5, v05 addition): Persona role-manifest enforcement.
#     For gates dated 2026-04-26 or later, frontmatter must contain a
#     `persona_role_manifest:` block with `path:` referencing a YAML file
#     under _grand_repo/role-manifests/ or workspace-equivalent. Path
#     must resolve to an existing file. Per /asae Aspect 9 (FM-1.2 role
#     mismatch closure). Deep scope_bounds verification deferred to v06;
#     this layer is presence-and-resolution.
#
#   Rule 8 (Tier 6, v05 addition): Inputs-processed verification.
#     For gates dated 2026-04-26 or later, frontmatter must contain an
#     `inputs_processed:` block. Each entry in `sources:` must have a
#     corresponding entry in `inputs_processed:` (presence check on
#     count parity). Per /asae Aspect 12 (FM-2.5 ignored-input closure).
#
# Tier 0 (deterministic-propagation class): commits carrying a
#   Propagation-From: trailer that references an existing gate-NN file
#   skip Rules 3-8. Rule 1 (persona) and Rule 2 (level-required trailer)
#   still apply. Designed for mechanical propagations (file copies from
#   a canonical source already audited at the source; submodule pointer
#   bumps; small doc-bump propagations) where per-target audit-log
#   overhead would be theatre, not assurance. The hook verifies the
#   referenced source-gate exists at a known location AND the staged
#   diff fits a bounded propagation profile (no source-code files,
#   total inserts + deletes under 10000 lines).
#
# Forward-only backfill posture for v05 tiers (1c-ext, 4-ext, 5, 6, 8):
#   gates dated 2026-04-26 or later must satisfy. Older gates grandfathered
#   (no retroactive backfill required). Detection: gate_id contains a
#   YYYY-MM-DD substring; if extracted date >= 2026-04-26, v05 tiers fire.
#
# Exempt from Rules 2-8: merge commits and revert commits.
#
# Known limitation: git commit --no-verify bypasses everything (architectural
# limit). For non-bypassable enforcement, layer a GitHub Actions required
# status check on push.

set -e

COMMIT_MSG_FILE="$1"

if [ ! -f "$COMMIT_MSG_FILE" ]; then
  echo "commit-msg hook: expected commit message file at '$COMMIT_MSG_FILE' but not found" >&2
  exit 1
fi

# ----------------------------------------------------------------------------
# Exemption: merge / revert commits skip Rules 2-8 (Rule 1 still applies)
# ----------------------------------------------------------------------------
SUBJECT=$(head -n 1 "$COMMIT_MSG_FILE" | sed -E 's/\r$//')
IS_EXEMPT_FROM_ASAE=false
if echo "$SUBJECT" | grep -qE '^(Merge |Revert )'; then
  IS_EXEMPT_FROM_ASAE=true
fi

# ============================================================================
# RULE 1 — IP-CLEAN PERSONA ATTRIBUTION (always)
# ============================================================================

COAUTHORS=$(grep -iE '^Co-Authored-By:' "$COMMIT_MSG_FILE" || true)

PERSONA_VIOLATIONS=""
PERSONA_VIOLATION_COUNT=0

if [ -n "$COAUTHORS" ]; then
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    line="${line%$'\r'}"
    persona=$(echo "$line" | sed -E 's/^[Cc]o-[Aa]uthored-[Bb]y:[[:space:]]*//' | sed -E 's/[[:space:]]*\(.*//')
    persona=$(echo "$persona" | sed -E 's/[[:space:]]+$//')
    if echo "$persona" | grep -qE '^[Cc]laude($|[[:space:]]|-|,)'; then
      PERSONA_VIOLATION_COUNT=$((PERSONA_VIOLATION_COUNT + 1))
      PERSONA_VIOLATIONS="${PERSONA_VIOLATIONS}
  Violation $PERSONA_VIOLATION_COUNT:
    Trailer line:   $line
    Persona parsed: '$persona'
    Problem:        Persona begins with 'Claude'. Per
                    feedback_clauda_replaces_claude_in_naming.md, Martinez
                    Methods thread personas use 'Clauda' or 'Claudette'
                    (not 'Claude')."
    fi
  done <<< "$COAUTHORS"
fi

if [ "$PERSONA_VIOLATION_COUNT" -gt 0 ]; then
  cat >&2 <<EOF

==================================================================
COMMIT REFUSED - Rule 1 violation: IP-clean persona attribution
==================================================================

Per \`feedback_clauda_replaces_claude_in_naming.md\`, Co-Authored-By
trailer persona names must use 'Clauda' or 'Claudette' (Martinez
Methods personifications), NOT 'Claude' (Anthropic's trademarked
product reserved for nominative references).

Nominative references to Anthropic's Claude model inside the
parenthetical model-spec (e.g., '(Claude Opus 4.7, 1M context)')
are allowed - they factually identify Anthropic's product.
$PERSONA_VIOLATIONS

Canonical format:
  Co-Authored-By: Clauda the Value Genius v02 (Opus 4.7, 1M context) <noreply@anthropic.com>
  Co-Authored-By: Claudette the Code Debugger (Opus 4.7, 1M context) <noreply@anthropic.com>
  Co-Authored-By: Clauda the Experiment PI (Opus 4.7, 1M context) <noreply@anthropic.com>

Fix the commit message and retry.

Emergency bypass (NOT RECOMMENDED):
  git commit --no-verify

EOF
  exit 1
fi

# ============================================================================
# RULES 2-8 — Gate enforcement (skipped for merge/revert)
# ============================================================================

if [ "$IS_EXEMPT_FROM_ASAE" = "true" ]; then
  exit 0
fi

# ---- Set REPO_ROOT and STAGED early (used by Tier 0 below) ----
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")
STAGED=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || echo "")

# ============================================================================
# TIER 0 — DETERMINISTIC-PROPAGATION CLASS (skips Rules 3-8 if matched)
# ============================================================================
# Trailer: Propagation-From: gate-NN-<source-descriptor>
# When present, the hook verifies (a) the referenced source-gate file exists
# at a known location, (b) the staged diff fits a bounded propagation profile.
# Rules 1 and 2 still apply; Rules 3-8 are skipped.

PROPAGATION_TRAILER=$(grep -iE '^Propagation-From:' "$COMMIT_MSG_FILE" | head -1 | sed -E 's/\r$//' || true)

IS_PROPAGATION_CLASS=false

if [ -n "$PROPAGATION_TRAILER" ]; then
  # Parse the referenced gate-NN-* identifier
  # v05.1 fix (gate-45): capture gate number only (not full descriptor).
  # Prior regex 'gate-[0-9]+(-[0-9a-z-]+)?' greedy-captured the full
  # 'gate-NN-<descriptor>-YYYY-MM-DD' string; the search at line ~225
  # then appends '-' producing '^gate-NN-<descriptor>-YYYY-MM-DD-' which
  # never matches files ending in '.md'. Capturing only the gate number
  # makes the search '^gate-NN-' work uniformly regardless of trailer form.
  PROP_GATE=$(echo "$PROPAGATION_TRAILER" | sed -E 's/^[Pp]ropagation-[Ff]rom:[[:space:]]*//' | grep -oE 'gate-[0-9]+' | head -1)

  PROP_GATE_FOUND=""
  if [ -n "$PROP_GATE" ]; then
    # Search known gate-file locations: this repo + workspace + _grand_repo
    for candidate_dir in \
        "$REPO_ROOT/deprecated/asae-logs" \
        "$REPO_ROOT/Deprecated/asae-logs" \
        "$REPO_ROOT/workspace/deprecated/asae-logs" \
        "$REPO_ROOT/../_grand_repo/deprecated/asae-logs" \
        "$HOME/_grand_repo/deprecated/asae-logs"; do
      if [ -d "$candidate_dir" ]; then
        FOUND=$(ls "$candidate_dir" 2>/dev/null | grep -iE "^${PROP_GATE}-" | head -1 || true)
        if [ -n "$FOUND" ]; then
          PROP_GATE_FOUND="$candidate_dir/$FOUND"
          break
        fi
      fi
    done
  fi

  # Bound the staged diff: no source-code files, total lines under 10000
  PROP_HAS_CODE=false
  if echo "$STAGED" | grep -qE '\.(ts|tsx|js|jsx|rs|py|go|java|c|cpp|h|hpp|rb|svelte|vue|sql)$|^src/|^src-tauri/|^plugin/(src|tests)/|^packages/'; then
    PROP_HAS_CODE=true
  fi
  PROP_LINE_COUNT=$(git diff --cached --numstat 2>/dev/null | awk '{s+=$1+$2} END{print s+0}')

  PROP_FAIL=""
  if [ -z "$PROP_GATE" ]; then
    PROP_FAIL="Propagation-From trailer present but no gate-NN reference parseable"
  elif [ -z "$PROP_GATE_FOUND" ]; then
    PROP_FAIL="Propagation-From references '$PROP_GATE' but no matching gate file found in any known location"
  elif [ "$PROP_HAS_CODE" = "true" ]; then
    PROP_FAIL="Propagation-From class does not accept source-code files; this commit stages code. Use D2R-Stage class for code commits."
  elif [ "$PROP_LINE_COUNT" -gt 10000 ]; then
    PROP_FAIL="Propagation-From class requires bounded diff (< 10000 lines); staged $PROP_LINE_COUNT lines exceed limit"
  fi

  if [ -n "$PROP_FAIL" ]; then
    cat >&2 <<EOF

==================================================================
COMMIT REFUSED - Tier 0 violation: invalid Propagation-From class
==================================================================

Trailer: $PROPAGATION_TRAILER
Problem: $PROP_FAIL

Propagation-From class is for mechanical propagations (file copies
from a canonical source already audited at the source; submodule
pointer bumps; small doc-bump propagations). Required:

  - Trailer references a gate-NN-* identifier that resolves to an
    existing gate file in a known location.
  - Staged diff contains no source-code files.
  - Staged diff total lines (inserts + deletes) under 10000.
  - Standard ASAE-Gate / D2R-Stage trailers and Rule 1 persona still
    required.

Use the regular ASAE-Gate / D2R-Stage class if this commit doesn't
fit the bounded propagation profile.

EOF
    exit 1
  fi

  # All Tier 0 checks pass — mark as propagation class and skip Rules 3-8
  IS_PROPAGATION_CLASS=true
fi

# ---- Resolve policy ----
POLICY_FILE="$REPO_ROOT/.asae-policy"

if [ -f "$POLICY_FILE" ]; then
  VISIBILITY=$(grep -E '^visibility:' "$POLICY_FILE" | head -1 | sed -E 's/^visibility:[[:space:]]*//' | tr -d ' ' | sed -E 's/\r$//')
  GOING_PUBLIC=$(grep -E '^going-public:' "$POLICY_FILE" | head -1 | sed -E 's/^going-public:[[:space:]]*//' | tr -d ' ' | sed -E 's/\r$//')
  REPO_TYPE=$(grep -E '^type:' "$POLICY_FILE" | head -1 | sed -E 's/^type:[[:space:]]*//' | tr -d ' ' | sed -E 's/\r$//')
else
  VISIBILITY="private"
  GOING_PUBLIC="true"
  REPO_TYPE="documentation"
fi

# ---- Derive required level ----
if [ "$VISIBILITY" = "public" ] || [ "$GOING_PUBLIC" = "true" ]; then
  REQUIRED_SEVERITY="strict"
  REQUIRED_THRESHOLD=3
else
  REQUIRED_SEVERITY="standard"
  REQUIRED_THRESHOLD=2
fi

# ---- Determine if this is a code commit in a codebase repo ----
IS_CODE_COMMIT=false
if [ "$REPO_TYPE" = "codebase" ]; then
  if echo "$STAGED" | grep -qE '\.(ts|tsx|js|jsx|rs|py|go|java|c|cpp|h|hpp|rb|svelte|vue|sql|yaml|yml|toml)$|^src/|^src-tauri/|^plugin/(src|tests)/|^packages/'; then
    IS_CODE_COMMIT=true
  fi
fi

# ---- Detect platform-conditional code paths (for Tier 3) ----
TOUCHES_PLATFORM_PATHS=false
if echo "$STAGED" | grep -qE '\.(ps1|cmd|bat)$|github/workflows|\.config\.(ts|js|mjs|cjs)$|propagate-githooks|installer'; then
  TOUCHES_PLATFORM_PATHS=true
fi
if [ "$TOUCHES_PLATFORM_PATHS" = "false" ] && [ -n "$STAGED" ]; then
  STAGED_DIFF=$(git diff --cached 2>/dev/null || echo "")
  if echo "$STAGED_DIFF" | grep -qE 'process\.env\.HOME|process\.env\.USERPROFILE|os\.homedir|pathToFileURL|path\.sep|process\.platform|win32|darwin|linux'; then
    TOUCHES_PLATFORM_PATHS=true
  fi
fi

# ============================================================================
# RULE 2 — TRAILER PRESENCE + LEVEL
# ============================================================================

ASAE_TRAILER=$(grep -iE '^ASAE-Gate:' "$COMMIT_MSG_FILE" | head -1 | sed -E 's/\r$//' || true)
D2R_TRAILER=$(grep -iE '^D2R-Stage:' "$COMMIT_MSG_FILE" | head -1 | sed -E 's/\r$//' || true)

ATTEST_OK=false
ATTEST_REASON=""
TRAILER_THRESH_NUMERIC=0

if [ "$IS_CODE_COMMIT" = "true" ] && [ -n "$D2R_TRAILER" ]; then
  D2R_STATUS=$(echo "$D2R_TRAILER" | sed -E 's/^[Dd]2[Rr]-[Ss]tage:[[:space:]]*//' | awk -F- '{print $NF}')
  if [ "$D2R_STATUS" = "PASS" ]; then
    ATTEST_OK=true
    TRAILER_THRESH_NUMERIC=$REQUIRED_THRESHOLD
  else
    ATTEST_REASON="D2R-Stage status '$D2R_STATUS' is not PASS"
  fi
elif [ -n "$ASAE_TRAILER" ]; then
  TRAILER_BODY=$(echo "$ASAE_TRAILER" | sed -E 's/^[Aa][Ss][Aa][Ee]-[Gg]ate:[[:space:]]*//')
  TRAILER_SEV=$(echo "$TRAILER_BODY" | awk -F- '{print $1}')
  TRAILER_THRESH=$(echo "$TRAILER_BODY" | awk -F- '{print $2}')
  TRAILER_STATUS=$(echo "$TRAILER_BODY" | awk -F- '{print $3}')

  if [ "$TRAILER_STATUS" != "PASS" ]; then
    ATTEST_REASON="ASAE-Gate status is '$TRAILER_STATUS', required 'PASS'"
  elif [ "$REQUIRED_SEVERITY" = "strict" ] && [ "$TRAILER_SEV" != "strict" ]; then
    ATTEST_REASON="This repo requires strict gate level; commit declares '$TRAILER_SEV'"
  elif ! echo "$TRAILER_THRESH" | grep -qE '^[0-9]+$'; then
    ATTEST_REASON="ASAE-Gate threshold '$TRAILER_THRESH' is not numeric"
  elif [ "$TRAILER_THRESH" -lt "$REQUIRED_THRESHOLD" ]; then
    ATTEST_REASON="ASAE-Gate threshold $TRAILER_THRESH < required $REQUIRED_THRESHOLD for this policy"
  else
    ATTEST_OK=true
    TRAILER_THRESH_NUMERIC=$TRAILER_THRESH
  fi
else
  ATTEST_REASON="No ASAE-Gate or D2R-Stage trailer found in commit message"
fi

if [ "$ATTEST_OK" != "true" ]; then
  cat >&2 <<EOF

==================================================================
COMMIT REFUSED - Rule 2 violation: gate trailer required
==================================================================

Policy resolved from $POLICY_FILE (or defaults):
  visibility:    $VISIBILITY
  going-public:  $GOING_PUBLIC
  type:          $REPO_TYPE
  is-code-commit: $IS_CODE_COMMIT

Required: $REQUIRED_SEVERITY level at threshold >= $REQUIRED_THRESHOLD
  (OR D2R-Stage PASS trailer if code commit in codebase repo)

Problem: $ATTEST_REASON

Canonical trailers:
  ASAE-Gate: strict-3-PASS          (public / going-public / non-code)
  ASAE-Gate: standard-2-PASS        (private, stable-private, non-code)
  D2R-Stage: 01b-PASS               (code commit, D2R stage cleared)

Fix: complete the methodology gate at the required level against the
staged changes, then add the trailer to the commit message body:

  <subject line>

  <optional body>

  ASAE-Gate: strict-3-PASS
  Co-Authored-By: Clauda the Value Genius v02 (Opus 4.7, 1M context) <noreply@anthropic.com>

Emergency bypass (NOT RECOMMENDED — defeats structural enforcement):
  git commit --no-verify

EOF
  exit 1
fi

# ============================================================================
# Skip Rules 3-8 for deterministic-propagation class
# ============================================================================
if [ "$IS_PROPAGATION_CLASS" = "true" ]; then
  exit 0
fi

# ============================================================================
# RULE 3 — TIER 1: BACKING-EVIDENCE FILE EXISTENCE
# ============================================================================

AUDIT_LOG_PATH=""

# Strategy 1: staged file under */asae-logs/gate-NN-*.md
STAGED_LOGS=$(echo "$STAGED" | grep -iE 'asae-logs/gate-[0-9]+(-[0-9]+)?-.+\.md$' || true)
if [ -n "$STAGED_LOGS" ]; then
  AUDIT_LOG_PATH=$(echo "$STAGED_LOGS" | sort -V | tail -1)
fi

# Strategy 2: body-referenced gate-NN, found in repo
if [ -z "$AUDIT_LOG_PATH" ]; then
  REFERENCED_GATE=$(grep -oiE 'gate-[0-9]+(-[0-9]+)?' "$COMMIT_MSG_FILE" | head -1 || true)
  if [ -n "$REFERENCED_GATE" ]; then
    LOWER_REF=$(echo "$REFERENCED_GATE" | tr '[:upper:]' '[:lower:]')
    for candidate_dir in "$REPO_ROOT/deprecated/asae-logs" "$REPO_ROOT/Deprecated/asae-logs" "$REPO_ROOT/workspace/deprecated/asae-logs"; do
      if [ -d "$candidate_dir" ]; then
        FOUND=$(ls "$candidate_dir" 2>/dev/null | grep -iE "^${LOWER_REF}-" | head -1 || true)
        if [ -n "$FOUND" ]; then
          AUDIT_LOG_PATH="${candidate_dir#$REPO_ROOT/}/$FOUND"
          break
        fi
      fi
    done
  fi
fi

if [ -z "$AUDIT_LOG_PATH" ] || [ ! -f "$REPO_ROOT/$AUDIT_LOG_PATH" ]; then
  cat >&2 <<EOF

==================================================================
COMMIT REFUSED - Rule 3 violation: backing-evidence file not found
==================================================================

The trailer attests a gate, but no corresponding internal-records
file was found.

Looked for:
  1. A staged file matching */asae-logs/gate-NN-*.md (preferred)
  2. A body-referenced gate-NN whose corresponding file exists at
     deprecated/asae-logs/gate-NN-*.md or workspace/deprecated/asae-logs/

Neither was found. Trailer presence alone is insufficient — the
trailer must be backed by a real file at the canonical path.

Fix:
  - Run the methodology gate at the required level against the staged
    changes per the canonical methodology spec.
  - Write the internal-records file at
    deprecated/asae-logs/gate-NN-<descriptor>.md
    with required frontmatter (gate_id, target, asae_certainty_threshold,
    Applied from) and Pass-N result blocks.
  - Stage the file as part of THIS commit, OR reference it by gate-NN
    in the commit body if it already exists in repo.

EOF
  exit 1
fi

AUDIT_LOG_FULL="$REPO_ROOT/$AUDIT_LOG_PATH"

GATE_ID=$(grep -E '^gate_id:' "$AUDIT_LOG_FULL" | head -1 | sed -E 's/^gate_id:[[:space:]]*//' | sed -E 's/\r$//' | sed -E 's/[[:space:]]+$//')
GATE_TARGET=$(grep -E '^target:' "$AUDIT_LOG_FULL" | head -1 | sed -E 's/^target:[[:space:]]*//' | sed -E 's/\r$//')
GATE_THRESHOLD=$(grep -E '^asae_certainty_threshold:' "$AUDIT_LOG_FULL" | head -1 | sed -E 's/^asae_certainty_threshold:[[:space:]]*//' | sed -E 's/\r$//' | sed -E 's/[[:space:]]+$//')

# ----------------------------------------------------------------------------
# Forward-only v05 detection: extract YYYY-MM-DD from gate_id and decide
# whether v05 tiers (1c-ext / 4-ext / 5 / 6 / 8) fire.
# ----------------------------------------------------------------------------
GATE_DATE=$(echo "$GATE_ID" | grep -oE '20[0-9]{2}-[0-9]{2}-[0-9]{2}' | head -1)
APPLY_V05_TIERS=false
if [ -n "$GATE_DATE" ] && [ "$GATE_DATE" \> "2026-04-25" ]; then
  APPLY_V05_TIERS=true
fi

# Required-phrase regex targets are mechanism-by-design and remain literal.
PASS_COUNT=$(grep -ciE '^##[[:space:]]+Pass [0-9]+' "$AUDIT_LOG_FULL" || echo "0")

TIER1_FAIL=""
if [ -z "$GATE_ID" ]; then
  TIER1_FAIL="internal-records file missing 'gate_id:' frontmatter field"
elif [ -z "$GATE_TARGET" ]; then
  TIER1_FAIL="internal-records file missing 'target:' frontmatter field"
elif [ -z "$GATE_THRESHOLD" ]; then
  TIER1_FAIL="internal-records file missing 'asae_certainty_threshold:' frontmatter field"
elif [ "$PASS_COUNT" -lt "$TRAILER_THRESH_NUMERIC" ]; then
  TIER1_FAIL="internal-records file contains $PASS_COUNT '## Pass N' headers but trailer claims threshold $TRAILER_THRESH_NUMERIC; need at least $TRAILER_THRESH_NUMERIC result-blocks"
fi

# Tier 1b: required-phrase markers in each Pass block. Marker regex is the
# mechanism contract with the canonical methodology spec; these literals are
# load-bearing and remain unchanged.
if [ -z "$TIER1_FAIL" ]; then
  awk '
    /^##[[:space:]]+Pass [0-9]+/ {
      if (in_pass) { check_pass(pass_id) }
      pass_id = $0
      pass_content = ""
      in_pass = 1
      next
    }
    /^##[[:space:]]/ {
      if (in_pass) { check_pass(pass_id); in_pass = 0 }
      next
    }
    in_pass { pass_content = pass_content "\n" $0 }
    END {
      if (in_pass) { check_pass(pass_id) }
    }
    function check_pass(id) {
      if (pass_content !~ /[Ii]ssues found at/) {
        print "MISSING_SEVERITY_BLOCK:" id
        exit 1
      }
      if (pass_content !~ /([Ff]ull[[:space:]]+(audit|checklist|domain|evaluation|re-evaluation)|[Cc]hecklist[[:space:]]+evaluation|[Aa]udit[[:space:]]+all[[:space:]]+items|[Ss]ame[[:space:]]+(scope|audit|comprehensive|evaluation))/) {
        print "MISSING_FULL_AUDIT_MARKER:" id
        exit 1
      }
      pass_content = ""
    }
  ' "$AUDIT_LOG_FULL" > /tmp/asae-pass-check.out 2>&1 || {
    PASS_CHECK_RESULT=$(cat /tmp/asae-pass-check.out 2>/dev/null || echo "unknown")
    if echo "$PASS_CHECK_RESULT" | grep -q "MISSING_SEVERITY_BLOCK"; then
      BAD_PASS=$(echo "$PASS_CHECK_RESULT" | sed -E 's/MISSING_SEVERITY_BLOCK://')
      TIER1_FAIL="Pass block '$BAD_PASS' missing 'Issues found at <severity>: <count>' summary"
    elif echo "$PASS_CHECK_RESULT" | grep -q "MISSING_FULL_AUDIT_MARKER"; then
      BAD_PASS=$(echo "$PASS_CHECK_RESULT" | sed -E 's/MISSING_FULL_AUDIT_MARKER://')
      TIER1_FAIL="Pass block '$BAD_PASS' missing required-phrase marker. See canonical methodology spec for accepted markers."
    fi
  }
  rm -f /tmp/asae-pass-check.out
fi

if [ -n "$TIER1_FAIL" ]; then
  cat >&2 <<EOF

==================================================================
