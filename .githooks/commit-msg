if [ "$IS_CODE_COMMIT" = "true" ]; then
  HAS_TEST_EXIT=$(grep -ciE 'EXIT_TEST[[:space:]]*[=:][[:space:]]*0|EXIT_TEST=0|tests passing.*EXIT.*0' "$AUDIT_LOG_FULL" || echo "0")
  HAS_BUILD_OR_TYPECHECK=$(grep -ciE 'EXIT_(BUILD|TYPECHECK|TC|LINT)[[:space:]]*[=:][[:space:]]*0' "$AUDIT_LOG_FULL" || echo "0")

  TIER2_FAIL=""
  if [ "$HAS_TEST_EXIT" = "0" ]; then
    TIER2_FAIL="internal-records file missing literal EXIT_TEST=0 claim"
  elif [ "$HAS_BUILD_OR_TYPECHECK" = "0" ]; then
    TIER2_FAIL="internal-records file missing literal EXIT_BUILD / EXIT_TYPECHECK / EXIT_LINT records"
  fi

  if [ -n "$TIER2_FAIL" ]; then
    cat >&2 <<EOF

==================================================================
COMMIT REFUSED - Rule 4 violation: observed-behavior claims missing
==================================================================

File:    $AUDIT_LOG_PATH
Problem: $TIER2_FAIL

Code commits in codebase repos must include observed-behavior
verification. The internal-records file must record literal shell
exit-code claims:

  EXIT_BUILD=0
  EXIT_TYPECHECK=0
  EXIT_LINT=0
  EXIT_TEST=0

Add a result-block to the file that ran these commands against the
staged content and records the literal exit codes:

  ## Pass N — observed-behavior verification

  \`\`\`
  EXIT_TYPECHECK=0   (npm run typecheck → tsc --noEmit clean)
  EXIT_LINT=0        (npm run lint → eslint clean)
  EXIT_BUILD=0       (npm run build → tsc clean)
  EXIT_TEST=0        (NNN/NNN tests passing across MM files)
  \`\`\`

  Issues found at strict severity: 0

EOF
    exit 1
  fi
fi

