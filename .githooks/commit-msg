GATE_NUMBER=$(echo "$GATE_ID" | sed -E 's/^gate-([0-9]+).*/\1/')
if echo "$GATE_NUMBER" | grep -qE '^[0-9]+$'; then
  for candidate_dir in "$REPO_ROOT/deprecated/asae-logs" "$REPO_ROOT/workspace/deprecated/asae-logs"; do
    if [ -d "$candidate_dir" ]; then
      COLLISIONS=$(ls "$candidate_dir" 2>/dev/null | grep -E "^gate-${GATE_NUMBER}-" || true)
      COLLISION_COUNT=$(echo "$COLLISIONS" | grep -c . || echo "0")
      if [ "$COLLISION_COUNT" -gt 1 ]; then
        cat >&2 <<EOF

==================================================================
COMMIT REFUSED - Rule 6 violation: gate ID collision
==================================================================

File:    $AUDIT_LOG_PATH
Gate ID: $GATE_ID
Problem: $COLLISION_COUNT files match gate-${GATE_NUMBER}-* in
         $candidate_dir — gate IDs must be unique:

$COLLISIONS

Fix: pick a higher gate-NN number for the new file.

EOF
        exit 1
      fi
    fi
  done
fi

HAS_APPLIED_FROM=$(grep -ciE '^(applied[[:space:]]*from|##[[:space:]]*applied[[:space:]]*from|sources:|origin:)' "$AUDIT_LOG_FULL" || echo "0")
