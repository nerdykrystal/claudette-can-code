if [ "$TOUCHES_PLATFORM_PATHS" = "true" ]; then
  HAS_GIT_BASH=$(grep -ciE 'git.bash|gitbash|bash[[:space:]]*\(?msys|posix shell' "$AUDIT_LOG_FULL" || echo "0")
  HAS_POWERSHELL=$(grep -ciE 'powershell|pwsh|cmd\.exe' "$AUDIT_LOG_FULL" || echo "0")

  if [ "$HAS_GIT_BASH" = "0" ] || [ "$HAS_POWERSHELL" = "0" ]; then
    cat >&2 <<EOF

==================================================================
COMMIT REFUSED - Rule 5 violation: cross-shell verification missing
==================================================================

File:    $AUDIT_LOG_PATH
Problem: file does not record cross-shell verification.

Staged content touches platform-conditional paths (HOME/USERPROFILE,
os.homedir, pathToFileURL, path.sep, process.platform, *.ps1/*.cmd
shims, GitHub Actions workflows). Single-shell verification masks
shell-specific portability bugs.

The file must record observed behavior in:
  - Git Bash (or equivalent POSIX shell on the build host), AND
  - PowerShell (pwsh or powershell.exe) — OR cmd.exe

Add a result-block:

